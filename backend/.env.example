# 数据库：Docker 内用 db:5432，本机直连用 localhost:5847
DATABASE_URL=postgresql://silicon:YOUR_POSTGRES_PASSWORD@db:5432/silicon_press
REDIS_URL=redis://redis:6379
LLM_CONFIG_PATH=/app/llm.json
REVIEW_EDITOR_KEYS=gemini-3.1-flash-lite,gpt-4o-mini,doubao-seed-2-0-lite-260215
CURATION_DAILY_LIMIT=15
CURATION_FRESH_WINDOW_HOURS=24
CURATION_FRESH_QUOTA_RATIO=0.3
CURATION_TIME_DECAY_PER_DAY=2.0
CURATION_ARCHIVE_AFTER_DAYS=7
PREVIEW_ADMIN_USERS=
OPENCLAW_CAPABILITY_ROUTE_PREFIX=/api/v1/openclaw-capability

# 与 DATABASE_URL 中的密码保持一致（供 docker-compose 的 db 服务使用）
POSTGRES_PASSWORD=YOUR_POSTGRES_PASSWORD

# JWT Auth（生产环境务必更换）
JWT_SECRET=your_jwt_secret_change_me_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# 可信代理 IP（逗号分隔），仅此时信任 X-Forwarded-For
TRUSTED_PROXY_IPS=
# HTTPS 环境下设为 true
COOKIE_SECURE=false

# Anonymous Submission Anti-Spam
ANON_COOKIE_NAME=spb_anon_id
ANON_COOKIE_MAX_AGE_SECONDS=31536000
ANON_SUBMIT_LIMIT_PER_MINUTE=1
ANON_SUBMIT_LIMIT_PER_HOUR=15
ANON_IP_LIMIT_PER_MINUTE=10
ANON_IP_LIMIT_PER_HOUR=120
ANON_DEDUP_TTL_SECONDS=600
USER_SUBMIT_LIMIT_PER_MINUTE=1
USER_SUBMIT_LIMIT_PER_HOUR=30

# Endpoint Rate Limit
LOGIN_IP_LIMIT_PER_MINUTE=20
LOGIN_USERNAME_LIMIT_PER_MINUTE=8
COMPARE_IP_LIMIT_PER_MINUTE=3
COMPARE_IP_LIMIT_PER_HOUR=20
COMPARE_USER_LIMIT_PER_MINUTE=6
COMPARE_USER_LIMIT_PER_HOUR=40
READ_API_IP_LIMIT_PER_MINUTE=120

# Redis 限流故障策略：true=放行（可用性优先），false=拒绝（安全优先）
RATE_LIMIT_FAIL_OPEN=true

# Email Service Configuration (QQ Enterprise Mail)
MAIL_SERVER_IMAP=imap.exmail.qq.com
MAIL_SERVER_IMAP_PORT=993
MAIL_SERVER_IMAP_SSL=true

MAIL_SERVER_SMTP=smtp.exmail.qq.com
MAIL_SERVER_SMTP_PORT=465
MAIL_SERVER_SMTP_SSL=true

MAIL_ENABLED=true
MAIL_FROM_ADDRESS=noreply@tensorout.com
MAIL_FROM_NAME=Silicon Press Bureau
MAIL_TIMEOUT_SECONDS=10
SITE_HOME_URL=https://sidaily.org/login

MAIL_USERNAME=noreply@tensorout.com
MAIL_PASSWORD=your_password_here
